{
  "name": "wavez-discord-presence",
  "version": "1.3.0",
  "description": "Local bridge that shows your currently playing wavez.fm tracks/status as Discord Rich Presence.",
  "license": "MIT",
  "main": "presence.js",
  "bin": {
    "wavez-discord-presence": "presence.js"
  },
  "files": [
    "presence.js",
    "config.example.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node presence.js",
    "test": "node tests/clean.test.js",
    "version": "node -e \"const f='wavez-discord-presence.user.js',fs=require('fs'),v=require('./package.json').version;fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(/(@version\\s+)[\\d.]+/,(m,p)=>p+v));console.log('userscript @version -> '+v)\" && git add wavez-discord-presence.user.js"
  },
  "keywords": [
    "wavez",
    "discord",
    "discord-rpc",
    "rich-presence",
    "userscript"
  ],
  "homepage": "https://github.com/fluteds/wavez-discord-presence",
  "repository": {
    "type": "git",
    "url": "https://github.com/fluteds/wavez-discord-presence.git"
  },
  "bugs": "https://github.com/fluteds/wavez-discord-presence/issues",
  "dependencies": {
    "@xhayper/discord-rpc": "^1.2.0"
  }
}
